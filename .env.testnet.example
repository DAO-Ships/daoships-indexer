# Quai Network (Orchard Testnet)
RPC_URL=https://rpc.orchard.quai.network
CHAIN_ID=15000

# Supabase Cloud
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SCHEMA=testnet

# Contract Addresses (Cyprus1 - Orchard Testnet)
DAOSHIP_AND_VAULT_LAUNCHER=0x00282d70dd7774B7c434DD97BF42E2B26B42F692
DAOSHIP_LAUNCHER=0x000C1C4f5e65B326DD3eb7Ae41DE8cbbdBcaB36D
POSTER=0x002b0a5Ae3268e6667CCdbacAEF33A9A3Da39820

# Indexer Configuration
POLL_INTERVAL_MS=5000
MAX_BLOCK_RANGE=100
CONFIRMATION_BLOCKS=3
START_BLOCK=0
LOG_LEVEL=info

# Reorg Detection
REORG_WALK_BACK=10

# Orphan Record Pruning (pre-DAO allowlist records)
ORPHAN_RETENTION_DAYS=90

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=8080
HEALTH_MAX_BLOCKS_BEHIND=100
HEALTH_CHECK_TIMEOUT_MS=10000
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://testnet.daoships.quaidao.org

# RPC Rate Limiting
RATE_LIMIT_REQUESTS=50
RATE_LIMIT_WINDOW_MS=1000

# Caching
TIMESTAMP_CACHE_SIZE=1000

# Retry Settings
RETRY_MAX_RETRIES=5
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=60000
RETRY_ERROR_THRESHOLD=3

# Backfill (for standalone backfill script)
# BACKFILL_FROM=5513600
# BACKFILL_TO=

# First run: SELECT create_ds_schema('testnet'); in Supabase SQL Editor
