# Quai Network (Mainnet)
RPC_URL=https://rpc.quai.network
CHAIN_ID=9000

# Supabase Cloud
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SCHEMA=mainnet

# Contract Addresses (Cyprus1 - Mainnet)
# Update these with mainnet deployment addresses
DAOSHIP_AND_VAULT_LAUNCHER=
DAOSHIP_LAUNCHER=
POSTER=

# Indexer Configuration
POLL_INTERVAL_MS=5000
MAX_BLOCK_RANGE=100
CONFIRMATION_BLOCKS=5
START_BLOCK=0
LOG_LEVEL=info

# Reorg Detection
REORG_WALK_BACK=10

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=8080
HEALTH_MAX_BLOCKS_BEHIND=100
HEALTH_CHECK_TIMEOUT_MS=10000
CORS_ALLOWED_ORIGINS=https://daoships.quaidao.org

# RPC Rate Limiting
RATE_LIMIT_REQUESTS=50
RATE_LIMIT_WINDOW_MS=1000

# Caching
TIMESTAMP_CACHE_SIZE=1000

# Retry Settings
RETRY_MAX_RETRIES=5
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=60000
RETRY_ERROR_THRESHOLD=3

# Backfill (for standalone backfill script)
# BACKFILL_FROM=
# BACKFILL_TO=

# First run: SELECT create_ds_schema('mainnet'); in Supabase SQL Editor
